        }
    },
    "m_Slots": [
        {
            "m_Id": "d39e5a4e6a2c420eac27e41ddf143776"
        },
        {
            "m_Id": "65b80d2f98764498987488b6ab8b873e"
        },
        {
            "m_Id": "87b691b6f8b54655bd8d8cbfe2637a0d"
        },
        {
            "m_Id": "23125e87c44d4dfb80691b1acd93047c"
        },
        {
            "m_Id": "4f9a8a8948454baba1e22351b5d51d7a"
        },
        {
            "m_Id": "b35dc83f7cfe4d64af689498601fc542"
        },
        {
            "m_Id": "04375413bead42a9963bdff950c2d998"
        },
        {
            "m_Id": "8990fbd3a7d54d22ad866ae959c244db"
        },
        {
            "m_Id": "cd4548a12fee4f098209376188f8c4a6"
        },
        {
            "m_Id": "498a7b259c5849aeac23343c43c4222b"
        },
        {
            "m_Id": "7b85297b1ddc467c88ee20c96a7af442"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "GerstnerWave",
    "m_FunctionSource": "dcf0fdbf7da1dba4299ef8771ce36e3e",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "void GerstnerWave_float(\r\n    float3 Position,\r\n    float2 Direction,\r\n    float Steepness,\r\n    float Wavelength,\r\n    float Speed,\r\n    float Time,\r\n    out float3 OutPosition,\r\n    out float3 OutNormal\r\n)\r\n{\r\n    float k = 2 * UNITY_PI / Wavelength;\r\n    float c = Speed;\r\n\r\n    float2 dir = normalize(Direction);\r\n\r\n    float f = k * (dot(dir, Position.xz) - c * Time);\r\n    float a = Steepness / k;\r\n\r\n    float cosF = cos(f);\r\n    float sinF = sin(f);\r\n\r\n    float3 displacement;\r\n\r\n    displacement.x = dir.x * (a * cosF);\r\n    displacement.y = a * sinF;\r\n    displacement.z = dir.y * (a * cosF);\r\n\r\n    OutPosition = Position + displacement;\r\n\r\n    float3 tangent = float3(\r\n        1 - dir.x * dir.x * Steepness * sinF,\r\n        dir.x * Steepness * cosF,\r\n        -dir.x * dir.y * Steepness * sinF\r\n    );\r\n\r\n    float3 binormal = float3(\r\n        -dir.x * dir.y * Steepness * sinF,\r\n        dir.y * Steepness * cosF,\r\n        1 - dir.y * dir.y * Steepness * sinF\r\n    );\r\n\r\n    OutNormal = normalize(cross(binormal, tangent));\r\n}"
}

